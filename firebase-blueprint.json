{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about users (clients, sellers, admins).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "seller", "admin"] },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Items listed for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "sellerId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a client and a seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "A review left for a seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A product favorited by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "A report on a product or user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["product", "user"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product listings" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Conversations" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Seller reviews" },
    "/users/{userId}/favorites/{productId}": { "schema": "Favorite", "description": "User favorites" },
    "/reports/{reportId}": { "schema": "Report", "description": "Moderation reports" }
  }
}
